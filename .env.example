# Copy to .env and fill in. Sourced by scripts/run_*.sh and scripts/setup.sh.
# Do not commit .env (already in .gitignore).

# ─── Backbone selection ─────────────────────────────────────────────────────
# SKILLDAG_BACKBONE: openai (default) | openrouter
#   openai     → OpenAI direct (primary reproducible path)
#   openrouter → OpenRouter (supports minimax/M2.7 and many other models)
SKILLDAG_BACKBONE=openai

# ─── Local interpreter used by scripts/setup.sh and scripts/run_*.sh ───
# scripts/prepare_env.sh rewrites this to an absolute Python >=3.10 path,
# preferring python3.11 when available.
PYTHON=python3.11
# Optional: keep the reproduction virtualenv somewhere other than ./.venv
# if your checkout is synced by Dropbox/Syncthing/etc.
# SKILLDAG_VENV=${REPO_ROOT}/.venv

# ─── OpenAI direct (default backbone) ───
OPENAI_API_KEY=sk-proj-...

# ─── OpenRouter (alternative backbone) ───
# Used when SKILLDAG_BACKBONE=openrouter.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter embedding model (openrouter supports openai-compatible embeddings)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large

# ─── ALFWorld agent (litellm) ────────────────────────────────────────────────
# Set SKILLDAG_BACKBONE=openai and these point at OpenAI:
#   SKILLDAG_API_KEY   → ${OPENAI_API_KEY}
#   SKILLDAG_API_BASE  → https://api.openai.com/v1
#   SKILLDAG_MODEL     → openai/gpt-5.2-codex
#
# Set SKILLDAG_BACKBONE=openrouter to use OpenRouter for ALFWorld:
#   SKILLDAG_API_KEY   → ${OPENROUTER_API_KEY}
#   SKILLDAG_API_BASE  → ${OPENROUTER_BASE_URL}
#   SKILLDAG_MODEL     → minimax/minimax-m2.7
SKILLDAG_API_KEY=${OPENAI_API_KEY}
SKILLDAG_API_BASE=https://api.openai.com/v1
SKILLDAG_MODEL=openai/gpt-5.2-codex

# ─── Graph initialization (cold-start) ─────────────────────────────────────
# Requires API key with LLM + embedding access. Defaults to SKILLDAG_MODEL.
SKILLDAG_LLM_API_KEY=${OPENAI_API_KEY}
SKILLDAG_LLM_MODEL=openai/gpt-5.2-codex

# ─── Embedding (used by `skilldag graph search` runtime queries) ────────────
SKILLDAG_EMBEDDING_API_KEY=${OPENAI_API_KEY}
SKILLDAG_EMBEDDING_BASE=https://api.openai.com/v1
SKILLDAG_EMBEDDING_MODEL=text-embedding-3-large

# ─── ALFWorld eval/utils.py reads these uppercase env vars at import time ───
API_KEY=${OPENAI_API_KEY}
BASE_URL=https://api.openai.com/v1

# ─── SkillsBench Codex CLI (Harbor's codex agent) ──────────────────────────
# Codex CLI reads these env vars at runtime inside the container.
# Default: Codex CLI uses its built-in OpenAI provider (direct).
# Set CODEX_BASE_URL to OpenRouter to switch backbone:
#   CODEX_BASE_URL=https://openrouter.ai/api/v1
#   CODEX_DEFAULT_MODEL=minimax/minimax-m2.7
CODEX_BASE_URL=
CODEX_PROVIDER_NAME=OpenAI
CODEX_WIRE_API=responses
CODEX_DEFAULT_MODEL=gpt-5.2-codex
CODEX_DEFAULT_REASONING=high
CODEX_CONTEXT_WINDOW=1000000

# ─── Optional: scale + concurrency for SkillsBench runs ───
# All 4 scales (200/500/1000/2000) have pre-built graph artifacts.
SKILLDAG_SCALE=1000             # benchmark scale (200 smoke / 500 / 1000 paper / 2000)
SKILLDAG_WORKERS=3                # n_concurrent_trials in Harbor

# ─── ALFWorld data root ───
# Install the alfworld package through scripts/setup.sh, then run the upstream
# data downloader if this directory does not exist.
ALFWORLD_DATA=${REPO_ROOT}/data/alfworld/data

# ─── PATH ────────────────────────────────────────────────────────────────────
# scripts/prepare_env.sh rewrites this with detected local tool directories.
# Codex CLI install: `brew install codex` → /opt/homebrew/bin on macOS arm64
PATH=${REPO_ROOT}/.venv/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}

# ─── Optional: HuggingFace token (only if datasets become gated) ───
# HF_TOKEN=hf_...